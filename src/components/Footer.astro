---
import { site } from "../data/site";
import { url } from "../utils/url";
---

<footer class="mt-24 border-t border-salmon-100 bg-gradient-to-b from-cream-50 to-cream-100">
  <div class="container-x py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-5">

    <!-- Logo + opis (2 kolumny na desktop) -->
    <div class="lg:col-span-2">
      <p class="font-serif text-2xl text-salmon-700 tracking-tight">medi<span class="text-salmon-500">3</span></p>
      <p class="mt-2 text-sm text-salmon-900/70 max-w-xs leading-relaxed">
        Kompleksowa opieka okołoporodowa — położne, szkoła rodzenia, fizjoterapia, neurologopedia.
        Mielec · Rzeszów.
      </p>
      <div class="mt-5 flex gap-3">
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"
           class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-salmon-200 text-salmon-700 hover:bg-white transition">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </a>
        <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook"
           class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-salmon-200 text-salmon-700 hover:bg-white transition">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true"><path d="M13.5 3h-3A4.5 4.5 0 0 0 6 7.5V10H4v3h2v8h3v-8h2.5l.5-3H9V7.5A1.5 1.5 0 0 1 10.5 6H13.5V3z"/></svg>
        </a>
      </div>
    </div>

    <!-- Kontakt -->
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-salmon-700/80">Kontakt</h4>
      <ul class="mt-3 space-y-2 text-sm text-salmon-900/80">
        <li><a href={`tel:${site.phoneTel}`} class="hover:text-salmon-700">{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`} class="hover:text-salmon-700">{site.email}</a></li>
        <li class="text-salmon-900/60 text-xs leading-snug">Mielec / Rzeszów<br/>Podkarpackie</li>
      </ul>
    </div>

    <!-- Usługi -->
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-salmon-700/80">Usługi</h4>
      <ul class="mt-3 space-y-2 text-sm text-salmon-900/80">
        <li><a href={url("/zapisy")} class="hover:text-salmon-700">Zapisy</a></li>
        <li><a href={url("/cennik")} class="hover:text-salmon-700">Cennik</a></li>
        <li><a href={url("/zespol")} class="hover:text-salmon-700">Zespół</a></li>
        <li><a href={url("/dojazd")} class="hover:text-salmon-700">Dojazd</a></li>
        <li><a href={url("/polozna-na-swoim")} class="hover:text-salmon-700">Położna na swoim</a></li>
      </ul>
    </div>

    <!-- Dokumenty -->
    <div>
      <h4 class="text-xs font-semibold uppercase tracking-wider text-salmon-700/80">Dokumenty</h4>
      <ul class="mt-3 space-y-2 text-sm text-salmon-900/80">
        <li><a href={url("/materialy")} class="hover:text-salmon-700">Materiały</a></li>
        <li><a href={url("/dane-do-szpitala")} class="hover:text-salmon-700">Dane do szpitala</a></li>
        <li><a href={url("/dane-do-przelewu")} class="hover:text-salmon-700">Dane do przelewu</a></li>
        <li><a href={url("/rodo")} class="hover:text-salmon-700">RODO</a></li>
        <li><a href={url("/regulamin")} class="hover:text-salmon-700">Regulamin</a></li>
      </ul>
    </div>

  </div>

  <div class="border-t border-salmon-100">
    <div class="container-x py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1.5 text-xs text-salmon-900/55">
      <p>© {new Date().getFullYear()} {site.foundation.name} · NIP {site.foundation.nip} · KRS {site.foundation.krs}</p>
      <p>{site.foundation.seat}</p>
    </div>
  </div>
</footer>
