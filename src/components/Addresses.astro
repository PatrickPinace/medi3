---
import { site } from "../data/site";
import { url } from "../utils/url";
---

<section id="dojazd" class="container-x py-16 md:py-20">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10 text-center md:text-left">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em]
        text-salmon-700/70 dark:text-salmon-300/70">Lokalizacje</p>
      <h2 class="mt-2 font-serif text-3xl sm:text-5xl tracking-tight leading-[1.15] sm:leading-tight
        text-salmon-800 dark:text-white/80">Jak do nas trafić</h2>
    </div>
    <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-5">
      <a href={url("/dane-do-przelewu")} class="inline-flex items-center gap-1.5 text-xs transition
        text-salmon-800/50 hover:text-salmon-700
        dark:text-navy-400 dark:hover:text-white">
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        Dane do przelewu
      </a>
      <a href={url("/dojazd")} class="text-sm font-medium transition inline-flex items-center justify-center gap-2
        text-salmon-700 hover:text-salmon-800
        dark:text-salmon-300/80 dark:hover:text-salmon-300">
        Pełna informacja o dojeździe
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {site.offices.map((o) => (
      <div class="relative overflow-hidden rounded-3xl border p-6 sm:p-8
        bg-gradient-to-br from-white to-cream-100 border-salmon-100
        dark:bg-none dark:border-white/10 dark:bg-white/5 dark:backdrop-blur-sm">
        <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full blur-2xl
          bg-blush-100 dark:bg-navy-600/40"></div>

        <div class="relative flex flex-col sm:flex-row items-center sm:items-start gap-4 text-center sm:text-left">
          <div class="shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-salmon-500 text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2.5"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-xs font-semibold uppercase tracking-wider
              text-salmon-700/70 dark:text-salmon-300/70">
              {o.key === "smoczka" ? "Główny gabinet" : "Nowy gabinet"}
            </p>
            <h3 class="mt-1 font-serif text-2xl text-salmon-800 dark:text-white/80">{o.name}</h3>
            <p class="mt-3 text-salmon-800/80 dark:text-navy-200">{o.address}</p>
            <p class="mt-1 text-sm text-salmon-800/60 dark:text-white/50">{o.hint}</p>

            <div class="mt-6 flex flex-col sm:flex-row sm:flex-wrap items-center sm:items-start gap-3">
              <a href={o.map} target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 text-xs">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2"/></svg>
                Otwórz w mapach
              </a>
              <a href={url("/dojazd")} class="text-sm inline-flex items-center gap-1 px-2 py-2.5 transition
                text-salmon-700/80 hover:text-salmon-700
                dark:text-navy-300 dark:hover:text-white">
                kliknij → szczegóły dojazdu
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
