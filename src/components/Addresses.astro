---
import { site } from "../data/site";
import { url } from "../utils/url";
---

<section id="dojazd" class="container-x py-20">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-salmon-700/70">Lokalizacje</p>
      <h2 class="mt-2 font-serif text-4xl sm:text-5xl text-salmon-900 tracking-tight">Jak do nas trafić</h2>
    </div>
    <a href={url("/dojazd")} class="text-sm font-medium text-salmon-700 hover:text-salmon-800 inline-flex items-center gap-2">
      Pełna informacja o dojeździe
      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {site.offices.map((o) => (
      <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-white to-cream-100 border border-salmon-100 p-7 sm:p-8">
        <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-blush-100 blur-2xl"></div>

        <div class="relative flex items-start gap-4">
          <div class="shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-salmon-500 text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2.5"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70">{o.key === "smoczka" ? "Główny gabinet" : "Nowy gabinet"}</p>
            <h3 class="mt-1 font-serif text-2xl text-salmon-900">{o.name}</h3>
            <p class="mt-3 text-salmon-900/80">{o.address}</p>
            <p class="mt-1 text-sm text-salmon-900/60">{o.hint}</p>

            <div class="mt-6 flex flex-wrap gap-3">
              <a href={o.map} target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 text-xs">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2"/></svg>
                Otwórz w mapach
              </a>
              <a href={url("/dojazd")} class="text-sm text-salmon-700/80 hover:text-salmon-700 inline-flex items-center gap-1 px-2 py-2.5">
                kliknij → szczegóły dojazdu
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
