---
import Logo from "./Logo.astro";
import { site } from "../data/site";
import { url } from "../utils/url";

const nav = [
  { href: url("/#uslugi"), label: "Usługi" },
  { href: url("/zapisy"), label: "Zapisy" },
  { href: url("/cennik"), label: "Cennik" },
  { href: url("/zespol"), label: "Zespół" },
  { href: url("/dojazd"), label: "Dojazd" },
];
---

<header class="sticky top-0 z-40 border-b transition-colors duration-300
  border-salmon-100/80 bg-cream-50/85 backdrop-blur
  dark:border-white/10 dark:bg-navy-800/80">
  <div class="container-x flex h-16 items-center justify-between gap-6">
    <Logo />

    <nav class="hidden lg:flex items-center gap-1">
      {nav.map((item) => (
        <a href={item.href} class="rounded-full px-3.5 py-2 text-sm transition
          text-salmon-900/75 hover:bg-salmon-100/70 hover:text-salmon-800
          dark:text-navy-200 dark:hover:bg-white/10 dark:hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a href={`tel:${site.phoneTel}`} class="text-sm transition
        text-salmon-800/80 hover:text-salmon-700
        dark:text-navy-300 dark:hover:text-white">
        {site.phone}
      </a>

      <!-- Przełącznik trybu -->
      <button
        id="theme-toggle"
        aria-label="Przełącz tryb jasny/ciemny"
        class="inline-flex h-8 w-8 items-center justify-center rounded-full border transition
          border-salmon-200 text-salmon-700 hover:bg-salmon-100
          dark:border-white/20 dark:text-navy-300 dark:hover:bg-white/10"
      >
        <!-- Ikona słońca (widoczna w ciemnym trybie) -->
        <svg id="icon-sun" viewBox="0 0 24 24" class="h-4 w-4 hidden" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <!-- Ikona księżyca (widoczna w jasnym trybie) -->
        <svg id="icon-moon" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href={url("/#zapisz-sie")} class="btn-primary !py-2 !px-4 text-xs">Umów wizytę</a>
    </div>

    <div class="flex md:hidden items-center gap-2">
      <!-- Przełącznik trybu mobile -->
      <button
        id="theme-toggle-mobile"
        aria-label="Przełącz tryb jasny/ciemny"
        class="inline-flex h-8 w-8 items-center justify-center rounded-full border transition
          border-salmon-200 text-salmon-700 hover:bg-salmon-100
          dark:border-white/20 dark:text-navy-300 dark:hover:bg-white/10"
      >
        <svg class="sun-icon h-4 w-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="moon-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button id="menu-btn" class="inline-flex h-10 w-10 items-center justify-center rounded-full border transition
        border-salmon-200 text-salmon-700
        dark:border-white/20 dark:text-white/80" aria-label="Menu">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t transition-colors
    border-salmon-100 bg-cream-50
    dark:border-white/10 dark:bg-navy-800">
    <nav class="container-x py-3 flex flex-col">
      {nav.map((item) => (
        <a href={item.href} class="rounded-xl px-3 py-2.5 text-sm transition
          text-salmon-900/80 hover:bg-salmon-100/60
          dark:text-navy-200 dark:hover:bg-white/10 dark:hover:text-white">
          {item.label}
        </a>
      ))}
      <a href={`tel:${site.phoneTel}`} class="mt-2 rounded-xl px-3 py-2.5 text-sm font-medium text-salmon-600 dark:text-salmon-300">
        ☎ {site.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  function initTheme() {
    const stored = localStorage.getItem("theme");
    // Jasny tryb domyślny - ciemny tylko gdy user sam wybrał
    const isDark = stored === "dark";
    document.documentElement.classList.toggle("dark", isDark);
    updateIcons(isDark);
  }

  function updateIcons(isDark: boolean) {
    document.querySelectorAll<HTMLElement>(".sun-icon, #icon-sun").forEach(el => {
      el.classList.toggle("hidden", !isDark);
    });
    document.querySelectorAll<HTMLElement>(".moon-icon, #icon-moon").forEach(el => {
      el.classList.toggle("hidden", isDark);
    });
  }

  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateIcons(isDark);
  }

  initTheme();

  document.getElementById("theme-toggle")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-mobile")?.addEventListener("click", toggleTheme);
  document.getElementById("menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
