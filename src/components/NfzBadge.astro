---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<span class={`inline-flex items-center rounded-full bg-white/70 border border-white/40 px-3 py-1.5 ${className}`}>
  <img src={`${base}/assets/nfz-logo.png`} alt="NFZ" class="h-5 w-auto" />
</span>
