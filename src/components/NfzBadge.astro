---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<span class={`inline-flex items-center gap-0.5 rounded-full bg-white/15 border border-white/25 px-2.5 py-1 text-white ${className}`}>
  <span class="text-xs font-bold tracking-tight leading-none">N</span>
  <svg viewBox="0 0 10 10" class="h-2.5 w-2.5 shrink-0" aria-hidden="true">
    <path d="M5 9 C5 9 1 6 1 3.5 C1 2.1 2.1 1 3.5 1 C4.3 1 5 1.7 5 1.7 C5 1.7 5.7 1 6.5 1 C7.9 1 9 2.1 9 3.5 C9 6 5 9 5 9Z" fill="#f43b84"/>
  </svg>
  <span class="text-xs font-bold tracking-tight leading-none">Z</span>
</span>
