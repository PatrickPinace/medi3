---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---

<section class="relative overflow-hidden border-b transition-colors
  border-salmon-100 dark:border-white/10">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-24 -left-24 h-80 w-80 rounded-full blur-3xl
      bg-salmon-200/55 dark:bg-purple-700/40"></div>
    <div class="absolute -top-10 right-0 h-80 w-80 rounded-full blur-3xl
      bg-peach-200/45 dark:bg-navy-600/40"></div>
  </div>

  <div class="container-x pt-10 pb-12 md:pt-20 md:pb-20 text-center md:text-left">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-[0.18em]
        text-salmon-700/70 dark:text-salmon-400/80">{eyebrow}</p>
    )}
    <h1 class="mt-3 font-serif text-3xl sm:text-5xl lg:text-6xl tracking-tight leading-[1.1] sm:leading-[1.05] max-w-3xl mx-auto md:mx-0
      text-salmon-900 dark:text-white">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-4 sm:mt-5 max-w-2xl mx-auto md:mx-0 text-base sm:text-lg leading-relaxed
        text-salmon-900/75 dark:text-navy-200">{subtitle}</p>
    )}
  </div>
</section>
