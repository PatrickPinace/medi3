---
import { site, forms } from "../data/site";
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 -left-24 h-96 w-96 rounded-full blur-3xl bg-salmon-200/60 dark:bg-purple-700/40"></div>
    <div class="absolute top-20 -right-32 h-[28rem] w-[28rem] rounded-full blur-3xl bg-peach-200/55 dark:bg-navy-600/50"></div>
    <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full blur-3xl bg-blush-200/70 dark:bg-salmon-500/10"></div>
  </div>

  <div class="container-x pt-10 md:pt-20 pb-16 md:pb-28 grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
    <div class="lg:col-span-7 text-center lg:text-left">
      <span class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-medium
        border-salmon-200/70 bg-white/60 text-salmon-700
        dark:border-white/20 dark:bg-white/10 dark:text-white/80">
        <span class="h-1.5 w-1.5 rounded-full bg-salmon-500 animate-pulse"></span>
        Świadczenia na NFZ i prywatnie
      </span>

      <h1 class="mt-5 sm:mt-6 font-serif text-4xl sm:text-6xl lg:text-[5.25rem] leading-[1.1] sm:leading-[1.08] tracking-tight
        text-salmon-900 dark:text-white">
        Kompleksowa<br />
        <span class="italic text-salmon-600 dark:text-salmon-400">opieka</span> okołoporodowa
      </h1>

      <p class="mt-5 sm:mt-7 max-w-xl mx-auto lg:mx-0 text-base sm:text-lg leading-relaxed
        text-salmon-900/75 dark:text-navy-200">
        Położne · Szkoła Rodzenia · Fizjoterapeuci · Neurologopedzi.<br/>
        Towarzyszymy w ciąży, podczas porodu i pierwszych miesiącach życia dziecka.
      </p>

      <div id="zapisz-sie" class="mt-7 sm:mt-9 flex flex-wrap justify-center lg:justify-start gap-3" style="scroll-margin-top: -218px">
        <a href={forms.ciaza} target="_blank" rel="noopener" class="btn-primary w-full sm:w-auto">
          <span>Zapisz się - jestem w ciąży</span>
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#uslugi" class="btn-ghost w-full sm:w-auto">Zobacz usługi</a>
      </div>

      <div class="mt-8 sm:mt-10 flex flex-wrap justify-center lg:justify-start items-center gap-x-6 sm:gap-x-8 gap-y-3 text-sm
        text-salmon-900/70 dark:text-navy-300">
        <a href={`tel:${site.phoneTel}`} class="inline-flex items-center gap-2 hover:text-salmon-700 dark:hover:text-white transition">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
          {site.phone}
        </a>
        <a href={`mailto:${site.email}`} class="inline-flex items-center gap-2 hover:text-salmon-700 dark:hover:text-white transition">
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
          {site.email}
        </a>
      </div>
    </div>

    <!-- Karuzela zdjęć -->
    <div class="lg:col-span-5 max-w-sm mx-auto lg:max-w-none w-full">
      <!-- Wrapper z animowaną wysokością — pionowe 4:5 domyślnie, poziome 3:2 dla zdjęcia grupowego -->
      <div id="hero-carousel-wrap" style="padding-bottom: 125%" class="relative w-full rounded-[2rem] overflow-hidden ring-1
        ring-salmon-200/60 shadow-[0_30px_60px_-30px_rgba(244,59,132,0.35)]
        dark:ring-white/20 dark:shadow-[0_30px_60px_-30px_rgba(56,32,82,0.8)]"
        data-aspects='["125%","125%","125%","66.7%","125%"]'>

        <div id="hero-carousel" class="absolute inset-0">

          <!-- Slajdy -->
          {[
            { src: "001.jpg", alt: "Specjalistka Medi3 z modelem miednicy", pos: "object-top" },
            { src: "184.jpg", alt: "Położna Medi3 z fantomem niemowlęcia", pos: "object-top" },
            { src: "222.jpg", alt: "Położna Medi3", pos: "object-top" },
            { src: "250.jpg", alt: "Zespół położnych Medi3", pos: "object-center" },
            { src: "299.jpg", alt: "Zespół Medi3 - położna i fizjoterapeuta", pos: "object-top" },
          ].map((s, i) => {
            const base = import.meta.env.BASE_URL.replace(/\/$/, '');
            return (
              <img
                src={`${base}/assets/galeria/${s.src}`}
                alt={s.alt}
                data-slide={i}
                class={`carousel-slide absolute inset-0 w-full h-full object-cover ${s.pos} transition-opacity duration-700 ${i === 0 ? "opacity-100" : "opacity-0"}`}
                loading={i === 0 ? "eager" : "lazy"}
              />
            );
          })}

          <!-- Badge NFZ — JS ustawia pozycję per slajd -->
          <div id="badge-nfz" class="absolute inline-flex items-center gap-2 rounded-full backdrop-blur px-3 py-1.5 text-xs font-medium shadow-sm
            bg-white/85 text-salmon-700 dark:bg-white/15 dark:text-white"
            style="top: 3.5rem; left: 1.5rem;">
            <span class="h-1.5 w-1.5 rounded-full bg-sage-500 dark:bg-green-400"></span> NFZ · bez skierowania
          </div>

          <!-- Badge Gabinety — JS ustawia pozycję per slajd -->
          <div id="badge-gabinety" class="absolute rounded-xl backdrop-blur px-3 py-1.5 text-xs font-medium shadow-sm
            bg-white/85 text-salmon-700 dark:bg-navy-900/70 dark:border dark:border-white/10 dark:text-white/70"
            style="top: 1.5rem; right: 1.5rem;">
            2 gabinety · Smoczka i Korczaka
          </div>

          <!-- Strzałki -->
          <button aria-label="Poprzednie zdjęcie" id="carousel-prev"
            class="absolute left-3 top-1/2 -translate-y-1/2 inline-flex h-9 w-9 items-center justify-center rounded-full backdrop-blur transition
              bg-white/70 text-salmon-700 hover:bg-white dark:bg-navy-900/60 dark:text-white dark:hover:bg-navy-900/80">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button aria-label="Następne zdjęcie" id="carousel-next"
            class="absolute right-3 top-1/2 -translate-y-1/2 inline-flex h-9 w-9 items-center justify-center rounded-full backdrop-blur transition
              bg-white/70 text-salmon-700 hover:bg-white dark:bg-navy-900/60 dark:text-white dark:hover:bg-navy-900/80">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>

          <!-- Dolny pasek: kropki w środku -->
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1.5">
            {[0,1,2,3,4].map((i) => (
              <button
                aria-label={`Zdjęcie ${i + 1}`}
                data-dot={i}
                class={`carousel-dot h-1.5 rounded-full transition-all duration-300 ${i === 0 ? "w-5 bg-white" : "w-1.5 bg-white/50"}`}
              />
            ))}
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".carousel-slide");
  const dots = document.querySelectorAll<HTMLElement>(".carousel-dot");
  const wrap = document.getElementById("hero-carousel-wrap") as HTMLElement;
  const badgeNfz = document.getElementById("badge-nfz") as HTMLElement;
  const badgeGabinety = document.getElementById("badge-gabinety") as HTMLElement;
  const aspects: string[] = JSON.parse(wrap?.dataset.aspects ?? "[]");
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  const T = "0.8s ease";
  wrap.style.transition = `padding-bottom ${T}, margin-left ${T}, width ${T}`;
  badgeNfz.style.transition = `top ${T}, bottom ${T}, left ${T}, right ${T}, opacity ${T}`;
  badgeGabinety.style.transition = `top ${T}, bottom ${T}, left ${T}, right ${T}, opacity ${T}`;

  function goTo(n: number) {
    slides[current].classList.replace("opacity-100", "opacity-0");
    dots[current].classList.remove("w-5", "bg-white");
    dots[current].classList.add("w-1.5", "bg-white/50");
    current = (n + slides.length) % slides.length;
    slides[current].classList.replace("opacity-0", "opacity-100");
    dots[current].classList.remove("w-1.5", "bg-white/50");
    dots[current].classList.add("w-5", "bg-white");
    if (aspects[current]) wrap.style.paddingBottom = aspects[current];

    const isWide = current === 3 && window.innerWidth >= 1024;
    wrap.style.marginLeft = isWide ? "-22%" : "0";
    wrap.style.width = isWide ? "122%" : "100%";

    if (current === 3) {
      // Zdjęcie grupowe — oba na dół, półprzezroczyste
      badgeNfz.style.top = "auto";
      badgeNfz.style.bottom = "0.75rem";
      badgeNfz.style.left = "1.5rem";
      badgeNfz.style.right = "auto";
      badgeNfz.style.opacity = "0.5";
      badgeGabinety.style.top = "auto";
      badgeGabinety.style.bottom = "0.75rem";
      badgeGabinety.style.left = "auto";
      badgeGabinety.style.right = "1.5rem";
      badgeGabinety.style.opacity = "0.5";
    } else if (current === 0) {
      // Blondynka — Gabinety góra prawa, NFZ góra lewa nieco niżej
      badgeGabinety.style.top = "1.5rem";
      badgeGabinety.style.bottom = "auto";
      badgeGabinety.style.left = "auto";
      badgeGabinety.style.right = "1.5rem";
      badgeGabinety.style.opacity = "1";
      badgeNfz.style.top = "3.5rem";
      badgeNfz.style.bottom = "auto";
      badgeNfz.style.left = "1.5rem";
      badgeNfz.style.right = "auto";
      badgeNfz.style.opacity = "1";
    } else {
      // Pozostałe — NFZ góra lewa, Gabinety pod spodem
      badgeNfz.style.top = "1.5rem";
      badgeNfz.style.bottom = "auto";
      badgeNfz.style.left = "1.5rem";
      badgeNfz.style.right = "auto";
      badgeNfz.style.opacity = "1";
      badgeGabinety.style.top = "4rem";
      badgeGabinety.style.bottom = "auto";
      badgeGabinety.style.left = "1.5rem";
      badgeGabinety.style.right = "auto";
      badgeGabinety.style.opacity = "1";
    }
  }

  function startAuto() {
    timer = setInterval(() => goTo(current + 1), 10000);
  }

  function resetAuto() {
    clearInterval(timer);
    startAuto();
  }

  document.getElementById("carousel-prev")?.addEventListener("click", () => { goTo(current - 1); resetAuto(); });
  document.getElementById("carousel-next")?.addEventListener("click", () => { goTo(current + 1); resetAuto(); });
  dots.forEach((dot) => {
    dot.addEventListener("click", () => { goTo(Number(dot.dataset.dot)); resetAuto(); });
  });

  startAuto();
</script>
