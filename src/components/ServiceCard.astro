---
import NfzBadge from "./NfzBadge.astro";

interface Props {
  title: string;
  description?: string;
  href: string;
  cta?: string;
  nfz?: boolean;
  size?: "lg" | "md";
  icon?: string;
  external?: boolean;
}
const {
  title,
  description = "",
  href,
  cta = "Zapisz się",
  nfz = false,
  size = "md",
  icon = "default",
  external = false,
} = Astro.props;

const isLarge = size === "lg";
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  class={`group relative flex flex-col justify-between overflow-hidden rounded-3xl border p-6 sm:p-7 transition text-center sm:text-left
    border-salmon-100/60 bg-white/70 backdrop-blur-sm shadow-[0_8px_30px_-12px_rgba(94,13,49,0.12)] hover:shadow-xl hover:-translate-y-0.5 hover:border-salmon-200
    dark:border-white/10 dark:bg-white/5 dark:backdrop-blur-sm dark:hover:bg-white/10 dark:hover:border-white/20
    ${isLarge ? "min-h-[17rem] sm:min-h-[19rem]" : "min-h-[14rem] sm:min-h-[15rem]"}`}
>
  <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full blur-2xl transition
    bg-salmon-100/60 group-hover:bg-salmon-200/70
    dark:bg-salmon-500/5 dark:group-hover:bg-salmon-500/15"></div>
  <div class="pointer-events-none absolute -left-10 -bottom-10 h-32 w-32 rounded-full blur-2xl opacity-0 transition group-hover:opacity-100
    bg-peach-100/40 dark:bg-white/5"></div>

  {nfz && <NfzBadge class="absolute top-4 right-4" />}

  <div class="relative">
    <div class="mx-auto sm:mx-0 mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl transition
      bg-salmon-100 text-salmon-600 group-hover:bg-salmon-400 group-hover:text-white
      dark:bg-white/10 dark:text-navy-200 dark:group-hover:bg-salmon-400/70 dark:group-hover:text-white">
      {icon === "stork" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.35-7-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 5.65-7 10-7 10z"/></svg>}
      {icon === "book" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h7a3 3 0 0 1 3 3v13H7a3 3 0 0 1-3-3z"/><path d="M20 4h-7a3 3 0 0 0-3 3v13h7a3 3 0 0 0 3-3z"/></svg>}
      {icon === "home" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"/><path d="M5 9v11h14V9"/><path d="M10 20v-6h4v6"/></svg>}
      {icon === "shield" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="M9 12l2 2 4-4"/></svg>}
      {icon === "ribbon" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/><path d="M9 13l-3 8 6-3 6 3-3-8"/></svg>}
      {icon === "drop" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s7 7.5 7 12a7 7 0 1 1-14 0c0-4.5 7-12 7-12z"/></svg>}
      {icon === "activity" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3-8 4 16 3-8h4"/></svg>}
      {icon === "alert" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><circle cx="12" cy="17" r=".5" fill="currentColor"/><path d="M10.3 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.7 3.86a2 2 0 0 0-3.4 0z"/></svg>}
      {icon === "speech" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>}
      {icon === "default" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16M4 12h16"/></svg>}
    </div>

    <h3 class={`font-serif tracking-tight ${isLarge ? "text-2xl sm:text-3xl" : "text-xl"}
      text-salmon-800 dark:text-white`}>
      {title}
    </h3>
    {description && (
      <p class={`mt-3 leading-relaxed text-justify ${isLarge ? "text-base" : "text-sm"}
        text-salmon-800/70 dark:text-navy-300`}>
        {description}
      </p>
    )}
  </div>

  <div class="relative mt-6 flex items-center justify-center sm:justify-between">
    <span class="inline-flex items-center gap-2 text-sm font-medium transition
      text-salmon-600 group-hover:text-salmon-700
      dark:text-salmon-300/80 dark:group-hover:text-salmon-300">
      {cta}
      <svg viewBox="0 0 24 24" class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </span>
  </div>
</a>
