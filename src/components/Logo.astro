---
import { url } from "../utils/url";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
interface Props { class?: string }
const { class: className = "" } = Astro.props;
---
<a href={url("/")} class={`group inline-flex items-center ${className}`} aria-label="Medi3 — strona główna">
  <img
    src={`${base}/assets/logo-medi3.png`}
    alt="Fundacja Medi3"
    class="h-10 w-auto"
  />
</a>
