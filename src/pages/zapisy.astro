---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import NfzBadge from "../components/NfzBadge.astro";
import { forms, site } from "../data/site";
import { url } from "../utils/url";

const grupy = [
  {
    nazwa: "Opieka okołoporodowa",
    opis: "Dla kobiet w ciąży, świeżo upieczonych mam i niemowląt - świadczenia NFZ bez skierowania.",
    pozycje: [
      { tytul: "Zapisy dla kobiet w ciąży (w tym Szkoła Rodzenia)", href: forms.ciaza, nfz: true },
      { tytul: "Wizyty patronażowe", href: forms.ciaza, nfz: true },
      { tytul: "Porada laktacyjna", href: forms.laktacyjna, nfz: false },
    ],
  },
  {
    nazwa: "Profilaktyka i badania",
    opis: "Badania profilaktyczne, programy NFZ i badania ginekologiczne.",
    pozycje: [
      { tytul: "Moje Zdrowie - badania profilaktyczne", href: forms.ogolny, nfz: true },
      { tytul: "Program wczesnego wykrywania raka szyjki", href: forms.ogolny, nfz: true },
      { tytul: "Badania ginekologiczne", href: forms.ogolny, nfz: false },
    ],
  },
  {
    nazwa: "Fizjoterapia i terapia",
    opis: "Diagnostyka i terapia dla niemowląt, dzieci, kobiet w okresie okołoporodowym i dorosłych.",
    pozycje: [
      { tytul: "Fizjoterapia", href: forms.ogolny, nfz: false },
      { tytul: "Neurologopeda - zadzwoń", href: `tel:${site.phoneTel}`, nfz: false, internal: true },
    ],
  },
  {
    nazwa: "Szkolenia i wydarzenia",
    opis: "Otwarte kursy i szkolenia dla rodziców i opiekunów.",
    pozycje: [
      { tytul: "Pierwsza Pomoc Noworodka i Niemowlęcia · 11.06.2026", href: forms.pierwszaPomoc, nfz: false },
    ],
  },
];
---

<BaseLayout
  title="Zapisy · Medi3"
  description="Wszystkie formularze zapisów do poradni Medi3 w jednym miejscu - ciąża, szkoła rodzenia, laktacja, profilaktyka, fizjoterapia, szkolenia."
>
  <PageHero
    eyebrow="Rejestracja"
    title="Zapisz się do Medi3"
    subtitle="Wybierz interesujące Cię świadczenie - przekierujemy do odpowiedniego formularza. W razie pytań zadzwoń."
  />

  <section class="container-x py-10 sm:py-12">
    <div class="rounded-3xl cta-gradient text-white dark:text-white/80 p-6 sm:p-8 flex flex-col sm:flex-row sm:items-center gap-5 justify-between text-center sm:text-left">
      <div>
        <p class="font-serif text-2xl">Wolisz porozmawiać?</p>
        <p class="text-white/85 dark:text-white/50 text-sm mt-1">Zadzwoń, a pomożemy wybrać odpowiednią formę opieki.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 flex-wrap justify-center">
        <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-salmon-700 px-5 py-2.5 text-sm font-medium hover:bg-navy-100 transition dark:bg-white/15 dark:text-white/70 dark:hover:bg-white/25">
          ☎ {site.phone}
        </a>
        <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 px-5 py-2.5 text-sm font-medium hover:bg-white/10 transition">
          {site.email}
        </a>
      </div>
    </div>
  </section>

  <section class="container-x pb-16 sm:pb-20">
    <div class="space-y-12">
      {grupy.map((g, idx) => (
        <div>
          <div class="flex items-baseline justify-between gap-4 mb-6 text-center md:text-left">
            <div class="mx-auto md:mx-0">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-salmon-400/70">Grupa {idx + 1}</p>
              <h2 class="mt-1 font-serif text-2xl sm:text-3xl text-salmon-900 dark:text-white/80 tracking-tight">{g.nazwa}</h2>
              <p class="mt-2 text-sm text-salmon-900/65 dark:text-navy-300 max-w-2xl">{g.opis}</p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {g.pozycje.map((p) => {
              const groupHasNfz = g.pozycje.some((x) => x.nfz);
              return (
              <a
                href={p.href}
                target={p.internal ? undefined : "_blank"}
                rel={p.internal ? undefined : "noopener noreferrer"}
                class={`group relative overflow-hidden rounded-3xl border p-4 sm:p-6 transition hover:-translate-y-0.5 hover:shadow-xl text-center sm:text-left
                  border-salmon-100 bg-white shadow-[0_2px_0_rgba(232,86,48,0.04)] hover:border-salmon-200
                  dark:border-white/10 dark:bg-white/5 dark:backdrop-blur-sm dark:hover:bg-white/10 dark:hover:border-white/20
                  flex flex-col ${p.nfz ? "min-h-[10rem] sm:min-h-[12rem]" : groupHasNfz ? "sm:min-h-[12rem]" : ""}`}
              >
                <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full blur-2xl transition
                  bg-salmon-100/60 group-hover:bg-salmon-200/70
                  dark:bg-salmon-500/5 dark:group-hover:bg-salmon-500/15"></div>
                <div class="pointer-events-none absolute -left-10 -bottom-10 h-32 w-32 rounded-full blur-2xl opacity-0 transition group-hover:opacity-100
                  bg-peach-100/40 dark:bg-white/5"></div>

                <div class="relative flex flex-col flex-1">
                  {p.nfz && (
                    <div class="mb-2 flex justify-center sm:justify-start">
                      <NfzBadge />
                    </div>
                  )}
                  <h3 class={`font-serif text-xl text-salmon-900 dark:text-white/80 leading-snug ${p.nfz ? "mt-auto" : groupHasNfz ? "sm:mt-auto" : ""}`}>{p.tytul}</h3>
                  <div class="mt-4 flex justify-center sm:justify-start">
                    <span class="inline-flex items-center gap-2 text-sm font-medium transition
                      text-salmon-400 group-hover:text-salmon-500
                      dark:text-salmon-300/80 dark:group-hover:text-salmon-300">
                      {p.internal ? "Zadzwoń" : "Wypełnij formularz"}
                      <svg viewBox="0 0 24 24" class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                    </span>
                  </div>
                </div>
              </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-xs text-salmon-900/40 dark:text-navy-400">
      Świadczenia odpłatne · <a href={url("/dane-do-przelewu")} class="inline-flex items-center gap-1 text-salmon-900/50 dark:text-navy-400 hover:text-salmon-700 dark:hover:text-white transition underline underline-offset-4 decoration-white/20">
        <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        dane do przelewu
      </a>
    </p>
  </section>
</BaseLayout>
