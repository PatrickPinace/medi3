---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CopyField from "../components/CopyField.astro";
import { site } from "../data/site";

const { accounts, zrzutka, recipient, address } = site.bank;
---

<BaseLayout
  title="Dane do przelewu · Medi3"
  description="Numery kont Fundacji Medi3 - Szkoła Rodzenia, szkolenia Medykalni, konto ogólne Nest Bank. Szybka płatność przez Zrzutka.pl."
>
  <PageHero
    eyebrow="Płatności"
    title="Dane do przelewu"
    subtitle="Każde konto służy innemu celowi - wybierz właściwe. Numer skopiujesz jednym kliknięciem."
  />

  <section class="container-x py-10 sm:py-12">

    <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 sm:p-7 mb-10 flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4">
      <div class="shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      </div>
      <p class="text-sm leading-relaxed text-salmon-900/80 dark:text-navy-200">
        Dotknij <strong class="text-salmon-900 dark:text-white/80">„Kopiuj numer"</strong> i wklej w aplikacji bankowej.
        Przy realizacji przelewu podaj w tytule swoje imię, nazwisko i cel wpłaty.
      </p>
    </div>

    <div class="space-y-6">
      {accounts.map((acc) => (
        <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 sm:p-8 relative overflow-hidden hover:border-white/20 transition">
          <div class="absolute -right-16 -top-16 h-48 w-48 rounded-full bg-salmon-500/5 blur-3xl pointer-events-none"></div>
          <div class="relative">

            <div class="flex items-start justify-between gap-4 flex-wrap mb-5 text-center sm:text-left">
              <div class="mx-auto sm:mx-0">
                <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/50 dark:text-white/40">
                  {acc.bankName ?? "Konto bankowe"}
                </p>
                <h2 class="mt-1 font-serif text-xl sm:text-2xl text-salmon-900 dark:text-white/80 tracking-tight">{acc.label}</h2>
                <p class="mt-1 text-sm text-salmon-900/70 dark:text-navy-300">{acc.description}</p>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4 bg-cream-100 dark:bg-navy-900/40 rounded-2xl px-5 py-4 border border-white/10 mb-5 text-center sm:text-left">
              <p class="font-mono text-xl sm:text-2xl text-salmon-900 dark:text-white/80 tracking-wider break-words">
                {acc.number}
              </p>
              <button
                type="button"
                data-copy={acc.number.replace(/\s+/g, "")}
                class="copy-btn shrink-0 inline-flex items-center justify-center gap-2 rounded-full bg-salmon-400 text-white px-5 py-2.5 text-sm font-medium hover:bg-salmon-500 transition dark:bg-salmon-400/70 dark:hover:bg-salmon-400/90"
                aria-label={`Skopiuj numer konta - ${acc.label}`}
              >
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2"/>
                  <path d="M5 15V5a2 2 0 0 1 2-2h10"/>
                </svg>
                <span class="copy-label">Kopiuj numer</span>
              </button>
            </div>

            <div class="grid sm:grid-cols-2 gap-3">
              <CopyField label="Odbiorca" value={recipient} />
              <CopyField label="Adres" value={address} />
              {"swift" in acc && acc.swift && (
                <CopyField label="SWIFT / BIC" value={acc.swift} mono />
              )}
              {"iban" in acc && acc.iban && (
                <CopyField label="IBAN" value={acc.iban} mono />
              )}
            </div>

          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-3xl border border-white/10 bg-white/5 p-6 sm:p-8 relative overflow-hidden">
      <div class="absolute -left-16 -bottom-16 h-48 w-48 rounded-full bg-salmon-500/5 blur-3xl pointer-events-none"></div>
      <div class="relative">
        <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4">
          <div class="shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-salmon-500/20 dark:text-salmon-400">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-7-4.35-7-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 5.65-7 10-7 10z"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/50 dark:text-white/40">Alternatywna płatność</p>
            <h2 class="mt-1 font-serif text-xl text-salmon-900 dark:text-white/80 tracking-tight">Szybki przelew przez Zrzutka.pl</h2>
            <p class="mt-3 text-sm text-salmon-900/70 dark:text-navy-300 leading-relaxed max-w-2xl">
              {zrzutka.note}
            </p>
            <a
              href={zrzutka.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 btn-primary inline-flex !py-2.5 !px-5 text-sm"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              Otwórz Zrzutka.pl
            </a>
          </div>
        </div>
      </div>
    </div>

  </section>

  <script>
    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const value = btn.dataset.copy ?? "";
        const label = btn.querySelector<HTMLElement>(".copy-label");
        try {
          await navigator.clipboard.writeText(value);
          if (label) {
            const prev = label.textContent;
            label.textContent = "Skopiowano ✓";
            setTimeout(() => { if (prev) label.textContent = prev; }, 1800);
          }
        } catch { /* no-op */ }
      });
    });
  </script>
</BaseLayout>
