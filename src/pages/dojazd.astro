---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Dojazd · Medi3"
  description="Jak dotrzeć do gabinetów Medi3 w Mielcu - Smoczka i Korczaka (LIBRA). Mapy, opisy dojazdu i wskazówki."
>
  <PageHero
    eyebrow="Lokalizacje"
    title="Jak do nas trafić"
    subtitle="Dwa gabinety w Mielcu - Smoczka (Wyszyńskiego) i nowy gabinet Korczaka (LIBRA, wjazd od ul. Czecha)."
  />

  <!-- Sekcja: Gabinet Smoczka -->
  <section class="container-x py-10 sm:py-16">
    <div class="rounded-[2rem] border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 dark:backdrop-blur-sm p-6 sm:p-10">
      <div class="grid lg:grid-cols-3 gap-6 items-start text-center lg:text-left">
        <div class="lg:col-span-2">
          <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70 dark:text-salmon-400/70">Główny gabinet</p>
          <h2 class="mt-2 font-serif text-3xl sm:text-4xl text-salmon-900 dark:text-white tracking-tight">Gabinet Smoczka</h2>
          <p class="mt-4 text-lg text-salmon-900/80 dark:text-navy-200">ul. Wyszyńskiego 4A/7</p>
          <p class="mt-1 text-sm text-salmon-700/50 dark:text-white/50">Centrum Medyczne Smoczka</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:flex-wrap justify-center lg:justify-end items-center gap-3">
          <a href="https://maps.app.goo.gl/siMucC1Sknxyfc8d6" target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 text-xs">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2"/></svg>
            Otwórz w mapach
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn-ghost !py-2.5 !px-5 text-xs">
            ☎ {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sekcja: Gabinet Korczaka + duże zdjęcie -->
  <section class="pb-10 sm:pb-16">
    <div class="container-x">
      <div class="rounded-[2rem] border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 dark:backdrop-blur-sm p-6 sm:p-10">
        <div class="grid lg:grid-cols-3 gap-6 items-start text-center lg:text-left">
          <div class="lg:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70 dark:text-salmon-400/70">Nowy gabinet</p>
            <h2 class="mt-2 font-serif text-3xl sm:text-4xl text-salmon-900 dark:text-white tracking-tight">Nowy Gabinet Korczaka</h2>
            <p class="mt-4 text-lg text-salmon-900/80 dark:text-navy-200">ul. Korczaka 1A (LIBRA)</p>
            <p class="mt-1 text-sm text-salmon-700/50 dark:text-white/50">wjazd od ul. Czecha, gabinet nr 5 (I piętro)</p>
          </div>
          <div class="flex flex-col sm:flex-row sm:flex-wrap justify-center lg:justify-end items-center gap-3">
            <a href="https://maps.app.goo.gl/zUK8VLPiQ4eFng359" target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 text-xs">
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2"/></svg>
              Otwórz w mapach
            </a>
            <a href={`tel:${site.phoneTel}`} class="btn-ghost !py-2.5 !px-5 text-xs">
              ☎ {site.phone}
            </a>
          </div>
        </div>
      </div>
    </div>

    <figure class="container-x mt-8">
      <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-navy-900/30 shadow-sm">
        <img
          src={`${base}/assets/libra-dojazd.jpg`}
          alt="Dojazd do gabinetu Korczaka (LIBRA) - mapa z oznaczeniami i widok ulicy"
          class="block w-full h-auto"
          loading="lazy"
        />
      </div>
      <figcaption class="mt-4 text-sm text-navy-300 text-center">
        Dojazd do nowego gabinetu Korczaka - LIBRA, ul. Korczaka 1A, wjazd od ul. Czecha.
      </figcaption>
    </figure>
  </section>

  <!-- Wskazówki praktyczne -->
  <section class="py-14 md:py-16" class="transition-colors bg-cream-100 dark:bg-black/20">
    <div class="container-x">
      <h2 class="font-serif text-3xl sm:text-4xl text-salmon-900 dark:text-white tracking-tight text-center md:text-left">Praktyczne wskazówki</h2>

      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 text-center sm:text-left">
          <div class="mx-auto sm:mx-0 inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200 mb-4">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><path d="M3 17h2M9 17h6M19 17h2M5 17l1.5-6h11L19 17"/></svg>
          </div>
          <h3 class="font-serif text-lg text-salmon-900 dark:text-white">Parking</h3>
          <p class="mt-2 text-sm leading-relaxed text-salmon-900/75 dark:text-navy-300">
            Przy obu gabinetach dostępne miejsca parkingowe. Gabinet Korczaka - wjazd od strony ul. Czecha,
            parking bezpośrednio przy budynku LIBRY.
          </p>
        </div>

        <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 text-center sm:text-left">
          <div class="mx-auto sm:mx-0 inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200 mb-4">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 2v4M16 2v4M3 10h18"/></svg>
          </div>
          <h3 class="font-serif text-lg text-salmon-900 dark:text-white">Umów wizytę</h3>
          <p class="mt-2 text-sm leading-relaxed text-salmon-900/75 dark:text-navy-300">
            Najlepiej skontaktuj się telefonicznie lub wypełnij formularz online - wskażemy gabinet
            dostosowany do typu wizyty i Twoich preferencji.
          </p>
        </div>

        <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 text-center sm:text-left">
          <div class="mx-auto sm:mx-0 inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200 mb-4">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="font-serif text-lg text-salmon-900 dark:text-white">Gabinet nr 5 (Korczaka)</h3>
          <p class="mt-2 text-sm leading-relaxed text-salmon-900/75 dark:text-navy-300">
            W budynku LIBRY przy ul. Korczaka 1A - gabinet nr 5 znajduje się na I piętrze.
            Po wejściu kieruj się schodami lub windą.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-x pb-16 sm:pb-20">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-salmon-500 via-salmon-600 to-peach-600 px-6 py-12 sm:px-14 sm:py-20 text-white">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -left-16 -bottom-24 h-80 w-80 rounded-full bg-white/5 blur-3xl"></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl sm:text-5xl tracking-tight leading-tight">Nie wiesz, do którego gabinetu?</h2>
        <p class="mt-4 text-white/85 text-base sm:text-lg">Zadzwoń lub napisz - pomożemy wybrać miejsce odpowiednie do Twojej wizyty.</p>
        <div class="mt-7 sm:mt-8 flex flex-wrap justify-center gap-3">
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-salmon-700 px-6 py-3 text-sm font-medium hover:bg-cream-50 transition w-full sm:w-auto">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
            {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 px-6 py-3 text-sm font-medium hover:bg-white/10 transition w-full sm:w-auto">
            {site.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
