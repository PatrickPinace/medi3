---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Dojazd · Medi3"
  description="Jak dotrzeć do gabinetów Medi3 w Mielcu — Smoczka i Korczaka (LIBRA). Mapy, opisy dojazdu i wskazówki."
>
  <PageHero
    eyebrow="Lokalizacje"
    title="Jak do nas trafić"
    subtitle="Dwa gabinety w Mielcu — Smoczka (Wyszyńskiego) i nowy gabinet Korczaka (LIBRA, wjazd od ul. Czecha)."
  />

  <!-- Sekcja: Gabinet Smoczka -->
  <section class="container-x py-12 sm:py-16">
    <div class="rounded-[2rem] border border-salmon-100 bg-gradient-to-br from-salmon-50 to-blush-100 p-7 sm:p-10">
      <div class="grid lg:grid-cols-3 gap-6 items-start">
        <div class="lg:col-span-2">
          <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70">Główny gabinet</p>
          <h2 class="mt-2 font-serif text-3xl sm:text-4xl text-salmon-900 tracking-tight">Gabinet Smoczka</h2>
          <p class="mt-4 text-lg text-salmon-900/85">ul. Wyszyńskiego 4A/7</p>
          <p class="mt-1 text-sm text-salmon-900/65">Centrum Medyczne Smoczka</p>
        </div>
        <div class="flex flex-wrap gap-3 lg:justify-end">
          <a href="https://maps.app.goo.gl/siMucC1Sknxyfc8d6" target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 text-xs">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2"/></svg>
            Otwórz w mapach
          </a>
          <a href={`tel:${site.phoneTel}`} class="btn-ghost !py-2.5 !px-5 text-xs">
            ☎ {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sekcja: Gabinet Korczaka + duże zdjęcie na całej szerokości -->
  <section class="pb-12 sm:pb-16">
    <div class="container-x">
      <div class="rounded-[2rem] border border-salmon-100 bg-gradient-to-br from-peach-50 to-cream-100 p-7 sm:p-10">
        <div class="grid lg:grid-cols-3 gap-6 items-start">
          <div class="lg:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70">Nowy gabinet</p>
            <h2 class="mt-2 font-serif text-3xl sm:text-4xl text-salmon-900 tracking-tight">Nowy Gabinet Korczaka</h2>
            <p class="mt-4 text-lg text-salmon-900/85">ul. Korczaka 1A (LIBRA)</p>
            <p class="mt-1 text-sm text-salmon-900/65">wjazd od ul. Czecha, gabinet nr 5 (I piętro)</p>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <a href="https://maps.app.goo.gl/zUK8VLPiQ4eFng359" target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 text-xs">
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-4.35-7-10a7 7 0 1 1 14 0c0 5.65-7 10-7 10z"/><circle cx="12" cy="11" r="2"/></svg>
              Otwórz w mapach
            </a>
            <a href={`tel:${site.phoneTel}`} class="btn-ghost !py-2.5 !px-5 text-xs">
              ☎ {site.phone}
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Zdjęcie wpisane w szerokość kontenera, w zaokrąglonej karcie -->
    <figure class="container-x mt-8">
      <div class="overflow-hidden rounded-[2rem] border border-salmon-100 bg-white shadow-sm">
        <img
          src={`${import.meta.env.BASE_URL}assets/libra-dojazd.jpg`}
          alt="Dojazd do gabinetu Korczaka (LIBRA) — mapa z oznaczeniami i widok ulicy"
          class="block w-full h-auto"
          loading="lazy"
        />
      </div>
      <figcaption class="mt-4 text-sm text-salmon-700/70 text-center">
        Dojazd do nowego gabinetu Korczaka — LIBRA, ul. Korczaka 1A, wjazd od ul. Czecha.
      </figcaption>
    </figure>
  </section>

  <!-- Wskazówki praktyczne -->
  <section class="bg-cream-100 py-16">
    <div class="container-x">
      <h2 class="font-serif text-3xl sm:text-4xl text-salmon-900 tracking-tight">Praktyczne wskazówki</h2>

      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="rounded-3xl bg-white border border-salmon-100 p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 mb-4">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><path d="M3 17h2M9 17h6M19 17h2M5 17l1.5-6h11L19 17"/></svg>
          </div>
          <h3 class="font-serif text-lg text-salmon-900">Parking</h3>
          <p class="mt-2 text-sm text-salmon-900/75 leading-relaxed">
            Przy obu gabinetach dostępne miejsca parkingowe. Gabinet Korczaka — wjazd od strony ul. Czecha,
            parking bezpośrednio przy budynku LIBRY.
          </p>
        </div>

        <div class="rounded-3xl bg-white border border-salmon-100 p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 mb-4">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 2v4M16 2v4M3 10h18"/></svg>
          </div>
          <h3 class="font-serif text-lg text-salmon-900">Umów wizytę</h3>
          <p class="mt-2 text-sm text-salmon-900/75 leading-relaxed">
            Najlepiej skontaktuj się telefonicznie lub wypełnij formularz online — wskażemy gabinet
            dostosowany do typu wizyty i Twoich preferencji.
          </p>
        </div>

        <div class="rounded-3xl bg-white border border-salmon-100 p-6">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 mb-4">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="font-serif text-lg text-salmon-900">Gabinet nr 5 (Korczaka)</h3>
          <p class="mt-2 text-sm text-salmon-900/75 leading-relaxed">
            W budynku LIBRY przy ul. Korczaka 1A — gabinet nr 5 znajduje się na I piętrze.
            Po wejściu kieruj się schodami lub windą.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-x py-20">
    <div class="rounded-[2rem] border border-salmon-100 bg-gradient-to-br from-salmon-50 to-cream-50 p-8 sm:p-12 text-center">
      <h2 class="font-serif text-3xl sm:text-4xl text-salmon-900 tracking-tight">Nie wiesz, do którego gabinetu?</h2>
      <p class="mt-3 text-salmon-900/75 max-w-xl mx-auto">Zadzwoń lub napisz — pomożemy wybrać miejsce odpowiednie do Twojej wizyty.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={`tel:${site.phoneTel}`} class="btn-primary">☎ {site.phone}</a>
        <a href={`mailto:${site.email}`} class="btn-ghost">{site.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>
