---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { team } from "../data/team";
import { site } from "../data/site";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const initials = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((s) => s[0]?.toUpperCase() ?? "")
    .join("");
---

<BaseLayout
  title="Zespół · Medi3"
  description="Poznaj zespół Medi3 - położne, fizjoterapeuci, neurologopedzi. Doświadczenie i ciepłe podejście do pacjentki."
>
  <PageHero
    eyebrow="Ludzie Medi3"
    title="Poznaj nasz zespół"
    subtitle="Położne, fizjoterapeuci i neurologopedzi - pracujemy zgrani, żeby kompleksowo zaopiekować się Tobą i Twoim dzieckiem."
  />

  <section class="container-x py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {team.map((m) => (
        <article class="group relative overflow-hidden rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 dark:backdrop-blur-sm transition hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5">
          <div class="aspect-[4/5] relative overflow-hidden bg-navy-700/60">
            {m.photo ? (
              <img src={`${base}${m.photo}`} alt={`${m.name} - ${m.role}`} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="font-serif text-6xl text-white/20 select-none">{initials(m.name)}</span>
              </div>
            )}
            <div class="absolute top-4 left-4 inline-flex items-center gap-1.5 rounded-full bg-navy-900/70 backdrop-blur px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-white/80">
              {m.role.split("·")[0].trim()}
            </div>
          </div>

          <div class="p-6 text-center sm:text-left">
            <h3 class="font-serif text-xl text-salmon-900 dark:text-white leading-tight">{m.name}</h3>
            <p class="mt-1 text-sm text-salmon-400/80">{m.role}</p>

            {m.specs.length > 0 && (
              <ul class="mt-4 flex flex-wrap justify-center sm:justify-start gap-1.5">
                {m.specs.map((s) => (
                  <li class="text-[11px] rounded-full px-2.5 py-1 border bg-salmon-50 text-salmon-700 border-salmon-100 dark:bg-white/10 dark:text-navy-200 dark:border-white/10">{s}</li>
                ))}
              </ul>
            )}

            <p class="mt-4 text-sm leading-relaxed text-salmon-900/75 dark:text-navy-300">{m.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="container-x pb-16 sm:pb-20">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-gradient-to-br from-salmon-500 via-salmon-600 to-peach-600 px-6 py-12 sm:px-14 sm:py-20 text-white">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -left-16 -bottom-24 h-80 w-80 rounded-full bg-white/5 blur-3xl"></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl sm:text-5xl tracking-tight leading-tight">Chcesz dołączyć do zespołu?</h2>
        <p class="mt-4 text-white/85 text-base sm:text-lg">Szukamy specjalistek i specjalistów z pasją do pracy z kobietami i rodzinami. Napisz do nas.</p>
        <div class="mt-7 sm:mt-8 flex flex-wrap justify-center gap-3">
          <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-salmon-700 px-6 py-3 text-sm font-medium hover:bg-cream-50 transition w-full sm:w-auto">
            {site.email}
          </a>
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 px-6 py-3 text-sm font-medium hover:bg-white/10 transition w-full sm:w-auto">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
            {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
