---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CopyField from "../components/CopyField.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Dane do szpitala · Medi3"
  description="Dane Fundacji Medi3, które warto mieć przy sobie wybierając się do szpitala - do podania przy rejestracji."
>
  <PageHero
    eyebrow="Praktyczne"
    title="Dane do szpitala"
    subtitle="Komplet danych Fundacji Medi3 - przyda się przy rejestracji w szpitalu lub w razie kontaktu z personelem medycznym. Każde pole możesz skopiować jednym kliknięciem."
  />

  <section class="container-x py-10 sm:py-12">
    <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 sm:p-7 flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-4 mb-10">
      <div class="shrink-0 inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      </div>
      <div>
        <p class="font-serif text-lg text-salmon-900 dark:text-white">Zapisz w telefonie</p>
        <p class="mt-1 text-sm text-salmon-900/70 dark:text-navy-300">
          Najprościej: dotknij przycisku "Kopiuj" przy interesującym polu i wklej w notatce.
          Strona działa też offline - możesz ją otworzyć w drodze do szpitala.
        </p>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <CopyField label="Nazwa podmiotu" value={site.foundation.name} big />
      <CopyField label="Siedziba" value={site.foundation.seat} />
      <CopyField label="NIP" value={site.foundation.nip} mono />
      <CopyField label="REGON" value={site.foundation.regon} mono />
      <CopyField label="KRS" value={site.foundation.krs} mono />
      <CopyField label="Numer księgi rejestrowej (NZOZ)" value="000000212438" mono />
    </div>

    <h2 class="mt-12 mb-4 font-serif text-2xl text-salmon-900 dark:text-white text-center md:text-left">Umowy z NFZ</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <CopyField label="Świętokrzyski OW NFZ" value="13-POZ01-19-04929-333" mono />
      <CopyField label="Podkarpacki OW NFZ" value="0903138101202013" mono />
    </div>

    <h2 class="mt-12 mb-4 font-serif text-2xl text-salmon-900 dark:text-white text-center md:text-left">Kontakt</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      <CopyField label="Telefon" value={site.phone} />
      <CopyField label="E-mail" value={site.email} />
      <CopyField label="Kierownik placówki" value="Artur Gładosz · 667 224 896" />
    </div>
  </section>

  <section class="container-x pb-16 sm:pb-20">
    <div class="rounded-[2rem] cta-gradient px-6 py-10 sm:px-12 sm:py-14 text-white relative overflow-hidden">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
      <div class="relative max-w-2xl mx-auto md:mx-0 text-center md:text-left">
        <h2 class="font-serif text-3xl tracking-tight">Pytania okołoporodowe?</h2>
        <p class="mt-3 text-white/85">Zadzwoń do swojej położnej - jesteśmy do Twojej dyspozycji.</p>
        <div class="mt-6">
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-salmon-700 px-6 py-3 text-sm font-medium hover:bg-navy-100 transition">
            ☎ {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
