---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import NfzBadge from "../components/NfzBadge.astro";
import { getEntry } from "astro:content";
import { site } from "../data/site";

const data = await getEntry("cennik", "uslugi");
const { kategorie } = data.data;

const formatPrice = (price: number, nfz?: boolean) => {
  if (nfz && price === 0) return null;
  return `${price} zł`;
};
---

<BaseLayout
  title="Cennik · Medi3"
  description="Cennik usług poradni Medi3 — badanie KTG, porada laktacyjna, fizjoterapia. Świadczenia NFZ i komercyjne."
>
  <PageHero
    eyebrow="Usługi i ceny"
    title="Cennik"
    subtitle="Poniżej aktualne ceny usług komercyjnych. Większość świadczeń dla kobiet w ciąży realizujemy bezpłatnie w ramach NFZ."
  />

  <section class="container-x py-12 sm:py-14 max-w-3xl">
    <div class="space-y-10">
      {kategorie.map((kat) => (
        <div>
          <h2 class="font-serif text-2xl text-white tracking-tight mb-1 text-center md:text-left">{kat.nazwa}</h2>
          <div class="mt-4 rounded-3xl border border-white/10 overflow-hidden bg-white/5">
            <ul class="divide-y divide-white/10">
              {kat.pozycje.map((p) => {
                const priceStr = formatPrice(p.price, p.nfz);
                return (
                  <li class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 px-5 sm:px-6 py-4 hover:bg-white/5 transition group text-center sm:text-left">
                    <span class="text-navy-100">{p.name}</span>
                    <div class="flex items-center justify-center sm:justify-end gap-3 shrink-0">
                      {p.nfz && <NfzBadge />}
                      {priceStr ? (
                        <span class="font-serif text-lg sm:text-xl text-salmon-400 tabular-nums">{priceStr}</span>
                      ) : (
                        <span class="text-xs text-green-400 font-medium">bezpłatnie</span>
                      )}
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-8 text-sm text-navy-400 text-center md:text-left">
      Ceny obowiązują od 2025 r. W razie pytań zadzwoń: <a href={`tel:${site.phoneTel}`} class="text-salmon-400 hover:text-salmon-300 underline underline-offset-4 transition">{site.phone}</a>
    </p>
  </section>

  <section class="container-x pb-16 sm:pb-20">
    <div class="rounded-[2rem] bg-gradient-to-br from-salmon-500 via-salmon-600 to-peach-600 px-6 py-10 sm:px-12 sm:py-14 text-white relative overflow-hidden">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
      <div class="relative max-w-2xl mx-auto md:mx-0 text-center md:text-left">
        <h2 class="font-serif text-3xl tracking-tight">Pytania o ceny lub NFZ?</h2>
        <p class="mt-3 text-white/85">Chętnie wyjaśnimy co przysługuje bezpłatnie i co jest odpłatne w Twojej sytuacji.</p>
        <div class="mt-7 flex flex-col sm:flex-row flex-wrap justify-center md:justify-start gap-3">
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-salmon-700 px-6 py-3 text-sm font-medium hover:bg-navy-100 transition">
            ☎ {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 px-6 py-3 text-sm font-medium hover:bg-white/10 transition">
            {site.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
