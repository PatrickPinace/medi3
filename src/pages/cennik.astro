---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import NfzBadge from "../components/NfzBadge.astro";
import { getEntry } from "astro:content";
import { site } from "../data/site";
import { url } from "../utils/url";

const data = await getEntry("cennik", "uslugi");
const { kategorie } = data.data;

const formatPrice = (price: number | string, nfz?: boolean) => {
  if (typeof price === "string") return price;
  if (nfz && price === 0) return null;
  return `${price} zł`;
};
---

<BaseLayout
  title="Cennik · Medi3"
  description="Cennik usług poradni Medi3 - badanie KTG, porada laktacyjna, fizjoterapia. Świadczenia NFZ i komercyjne."
>
  <PageHero
    eyebrow="Usługi i ceny"
    title="Cennik"
    subtitle="Poniżej aktualne ceny usług komercyjnych. Większość świadczeń dla kobiet w ciąży realizujemy bezpłatnie w ramach NFZ."
  />

  <section class="container-x py-12 sm:py-14 max-w-3xl">
    <div class="space-y-10">
      {kategorie.map((kat) => (
        <div>
          <h2 class="font-serif text-2xl text-salmon-900 dark:text-white tracking-tight mb-1 text-center md:text-left">{kat.nazwa}</h2>
          <div class="mt-4 rounded-3xl overflow-hidden border bg-white border-salmon-100 dark:border-white/10 dark:bg-white/5">
            <ul class="divide-y divide-salmon-100 dark:divide-white/10">
              {kat.pozycje.map((p) => {
                const priceStr = formatPrice(p.price, p.nfz);
                return (
                  <li class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 px-5 sm:px-6 py-4 hover:bg-salmon-50 dark:hover:bg-white/5 transition group text-center sm:text-left">
                    <span class="text-salmon-900 dark:text-navy-100">{p.name}</span>
                    <div class="flex items-center justify-center sm:justify-end gap-3 shrink-0">
                      {p.nfz && <NfzBadge />}
                      {priceStr ? (
                        <span class="font-serif text-lg sm:text-xl text-salmon-400 tabular-nums">{priceStr}</span>
                      ) : (
                        <span class="text-xs text-green-400 font-medium">bezpłatnie</span>
                      )}
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-center md:text-left">
      <p class="text-sm text-salmon-900/40 dark:text-navy-400">
        Ceny obowiązują od 2025 r. W razie pytań zadzwoń: <a href={`tel:${site.phoneTel}`} class="text-salmon-400 hover:text-salmon-300 underline underline-offset-4 transition">{site.phone}</a>
      </p>
      <a href={url("/dane-do-przelewu")} class="inline-flex items-center gap-1.5 text-xs text-salmon-900/50 hover:text-salmon-700 dark:text-navy-400 dark:hover:text-white transition shrink-0 justify-center sm:justify-start">
        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        Dane do przelewu →
      </a>
    </div>
  </section>

  <section class="container-x pb-16 sm:pb-20">
    <div class="relative overflow-hidden rounded-[2.5rem] cta-gradient px-6 py-12 sm:px-14 sm:py-20 text-white">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -left-16 -bottom-24 h-80 w-80 rounded-full bg-white/5 blur-3xl"></div>
      <div class="relative max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl sm:text-5xl tracking-tight leading-tight">Pytania o ceny lub NFZ?</h2>
        <p class="mt-4 text-white/85 text-base sm:text-lg">Chętnie wyjaśnimy co przysługuje bezpłatnie i co jest odpłatne w Twojej sytuacji.</p>
        <div class="mt-7 sm:mt-8 flex flex-wrap justify-center gap-3">
          <a href={`tel:${site.phoneTel}`} class="inline-flex items-center justify-center gap-2 rounded-full bg-white text-salmon-700 px-6 py-3 text-sm font-medium hover:bg-cream-50 transition w-full sm:w-auto">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 6 6L15 14l5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg>
            {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/40 px-6 py-3 text-sm font-medium hover:bg-white/10 transition w-full sm:w-auto">
            {site.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
