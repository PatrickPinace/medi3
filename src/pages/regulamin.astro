---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Regulamin organizacyjny · Medi3"
  description="Regulamin organizacyjny NZOZ Medi3 — Fundacja Medi3 z siedzibą w Mielcu."
>
  <PageHero
    eyebrow="Dokument"
    title="Regulamin organizacyjny"
    subtitle="Regulamin podmiotu leczniczego NZOZ Medi3, prowadzonego przez Fundację Medi3 z siedzibą w Mielcu."
  />

  <section class="container-x py-16">
    <div class="grid lg:grid-cols-3 gap-10">
      <aside class="lg:col-span-1">
        <div class="sticky top-24 rounded-3xl border border-salmon-100 bg-white p-6">
          <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70">Dokument</p>
          <p class="mt-2 font-serif text-lg text-salmon-900">Regulamin organizacyjny</p>
          <p class="mt-2 text-xs text-salmon-700/60">{site.foundation.name}</p>
          <p class="text-xs text-salmon-700/60">{site.foundation.seat}</p>

          <p class="mt-6 text-xs font-semibold uppercase tracking-wider text-salmon-700/70">Kontakt</p>
          <ul class="mt-2 space-y-1 text-sm text-salmon-900/80">
            <li>{site.phone}</li>
            <li>{site.email}</li>
          </ul>
        </div>
      </aside>

      <article class="lg:col-span-2">
        <!-- Placeholder treści -->
        <div class="rounded-3xl border border-dashed border-salmon-300 bg-salmon-50/60 p-8 sm:p-10">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-salmon-600 mb-5">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6M8 13h8M8 17h5"/></svg>
          </div>
          <h2 class="font-serif text-2xl text-salmon-900">Treść regulaminu — w przygotowaniu</h2>
          <p class="mt-3 text-salmon-900/75 leading-relaxed">
            Aktualnie pracujemy nad finalną wersją Regulaminu organizacyjnego NZOZ Medi3.
            Pełna treść pojawi się w tym miejscu, gdy zostanie zatwierdzona.
          </p>
          <p class="mt-3 text-salmon-900/75 leading-relaxed">
            Jeśli potrzebujesz wglądu do regulaminu teraz, napisz lub zadzwoń — chętnie prześlemy aktualną wersję.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href={`mailto:${site.email}`} class="btn-primary !py-2.5 !px-5 text-xs">Poproś o regulamin</a>
            <a href={`tel:${site.phoneTel}`} class="btn-ghost !py-2.5 !px-5 text-xs">☎ {site.phone}</a>
          </div>
        </div>

        <!-- Linkowane sąsiednie dokumenty -->
        <div class="mt-10 grid sm:grid-cols-2 gap-4">
          <a href="/rodo" class="rounded-2xl border border-salmon-100 bg-white p-5 hover:border-salmon-200 hover:shadow-sm transition">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70">Powiązane</p>
            <p class="mt-2 font-serif text-lg text-salmon-900">RODO i cele Fundacji →</p>
            <p class="mt-1 text-sm text-salmon-700/70">Klauzula informacyjna i cele statutowe.</p>
          </a>
          <a href="/dane-do-szpitala" class="rounded-2xl border border-salmon-100 bg-white p-5 hover:border-salmon-200 hover:shadow-sm transition">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/70">Powiązane</p>
            <p class="mt-2 font-serif text-lg text-salmon-900">Dane do szpitala →</p>
            <p class="mt-1 text-sm text-salmon-700/70">Komplet danych Fundacji do podania w szpitalu.</p>
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
