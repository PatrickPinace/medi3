---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";
import { url } from "../utils/url";
---

<BaseLayout
  title="Regulamin organizacyjny · Medi3"
  description="Regulamin organizacyjny NZOZ Medi3 - Fundacja Medi3 z siedzibą w Mielcu."
>
  <PageHero
    eyebrow="Dokument"
    title="Regulamin organizacyjny"
    subtitle="Regulamin podmiotu leczniczego NZOZ Medi3, prowadzonego przez Fundację Medi3 z siedzibą w Mielcu."
  />

  <section class="container-x py-12 sm:py-16">
    <div class="grid lg:grid-cols-3 gap-10">
      <aside class="lg:col-span-1">
        <div class="sticky top-24 rounded-3xl border border-white/10 bg-white/5 p-6 text-center lg:text-left">
          <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/50 dark:text-white/40">Dokument</p>
          <p class="mt-2 font-serif text-lg text-salmon-900 dark:text-white/80">Regulamin organizacyjny</p>
          <p class="mt-2 text-xs text-salmon-700/50 dark:text-white/40">{site.foundation.name}</p>
          <p class="text-xs text-salmon-700/50 dark:text-white/40">{site.foundation.seat}</p>

          <p class="mt-6 text-xs font-semibold uppercase tracking-wider text-salmon-700/50 dark:text-white/40">Kontakt</p>
          <ul class="mt-2 space-y-1 text-sm text-salmon-900/80 dark:text-navy-200">
            <li>{site.phone}</li>
            <li>{site.email}</li>
          </ul>
        </div>
      </aside>

      <article class="lg:col-span-2">
        <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 sm:p-10 text-center sm:text-left">
          <div class="mx-auto sm:mx-0 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 text-navy-200 mb-5">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6M8 13h8M8 17h5"/></svg>
          </div>
          <h2 class="font-serif text-2xl text-salmon-900 dark:text-white/80">Treść regulaminu - w przygotowaniu</h2>
          <p class="mt-3 leading-relaxed text-salmon-900/75 dark:text-navy-300">
            Aktualnie pracujemy nad finalną wersją Regulaminu organizacyjnego NZOZ Medi3.
            Pełna treść pojawi się w tym miejscu, gdy zostanie zatwierdzona.
          </p>
          <p class="mt-3 leading-relaxed text-salmon-900/75 dark:text-navy-300">
            Jeśli potrzebujesz wglądu do regulaminu teraz, napisz lub zadzwoń - chętnie prześlemy aktualną wersję.
          </p>
          <div class="mt-7 flex flex-col sm:flex-row flex-wrap justify-center sm:justify-start gap-3">
            <a href={`mailto:${site.email}`} class="btn-primary !py-2.5 !px-5 text-xs">Poproś o regulamin</a>
            <a href={`tel:${site.phoneTel}`} class="btn-ghost !py-2.5 !px-5 text-xs">☎ {site.phone}</a>
          </div>
        </div>

        <div class="mt-10 grid sm:grid-cols-2 gap-4">
          <a href={url("/rodo")} class="rounded-2xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-5 hover:border-white/20 hover:bg-white/10 transition text-center sm:text-left">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/50 dark:text-white/40">Powiązane</p>
            <p class="mt-2 font-serif text-lg text-salmon-900 dark:text-white/80">RODO i cele Fundacji →</p>
            <p class="mt-1 text-sm text-salmon-900/70 dark:text-navy-300">Klauzula informacyjna i cele statutowe.</p>
          </a>
          <a href={url("/dane-do-szpitala")} class="rounded-2xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-5 hover:border-white/20 hover:bg-white/10 transition text-center sm:text-left">
            <p class="text-xs font-semibold uppercase tracking-wider text-salmon-700/50 dark:text-white/40">Powiązane</p>
            <p class="mt-2 font-serif text-lg text-salmon-900 dark:text-white/80">Dane do szpitala →</p>
            <p class="mt-1 text-sm text-salmon-900/70 dark:text-navy-300">Komplet danych Fundacji do podania w szpitalu.</p>
          </a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
