---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { resources } from "../data/site";

const materialy = [
  {
    tytul: "Kalkulator tygodnia ciąży",
    opis: "Sprawdź, w którym tygodniu ciąży aktualnie jesteś i jaka jest przewidywana data porodu.",
    href: resources.kalkulatorTygodnia,
    kategoria: "Narzędzie",
    ikona: "calendar",
  },
  {
    tytul: "Kalkulator przyrostu masy noworodka",
    opis: "Monitoruj prawidłowy przyrost wagi Twojego dziecka w pierwszych tygodniach życia.",
    href: resources.kalkulatorWagi,
    kategoria: "Narzędzie",
    ikona: "scale",
  },
  {
    tytul: "Plan porodu - wzór edytowalny",
    opis: "Gotowy szablon planu porodu w formacie Word - pobierz, dostosuj i zabierz ze sobą do szpitala.",
    href: resources.planPorodu,
    kategoria: "Dokument",
    ikona: "document",
  },
  {
    tytul: "Kalendarz wizyt zespołu Medi3",
    opis: "Sprawdź dostępne terminy i umów się online z położną, fizjoterapeutą lub neurologopedą.",
    href: resources.kalendarz,
    kategoria: "Rezerwacja",
    ikona: "calendar",
  },
  {
    tytul: "Medykalni - szkolenia dla personelu medycznego",
    opis: "Nasza inicjatywa edukacyjna dla personelu medycznego. Warsztaty, kursy i konferencje.",
    href: resources.medykalni,
    kategoria: "Edukacja",
    ikona: "graduation",
  },
];
---

<BaseLayout
  title="Materiały dla pacjentów · Medi3"
  description="Kalkulatory, plan porodu, kalendarz wizyt i materiały edukacyjne dla pacjentek poradni Medi3."
>
  <PageHero
    eyebrow="Strefa pacjenta"
    title="Materiały dla pacjentów"
    subtitle="Narzędzia, dokumenty i materiały, które mogą Ci pomóc - od kalkulatora tygodnia ciąży po wzór planu porodu."
  />

  <section class="container-x py-12 sm:py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {materialy.map((m) => (
        <a
          href={m.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-3xl border p-6 sm:p-7 transition hover:-translate-y-0.5 text-center sm:text-left border-salmon-100 bg-white hover:border-salmon-200 hover:bg-salmon-50 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10 dark:hover:border-white/20"
        >
          <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-salmon-500/5 blur-2xl transition group-hover:bg-salmon-500/15"></div>

          <div class="relative">
            <div class="flex items-center justify-center sm:justify-between gap-3 mb-5">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl transition group-hover:bg-salmon-500 group-hover:text-white bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200">
                {m.ikona === "calendar" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 11h18"/></svg>}
                {m.ikona === "scale" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 21h12M12 3v18M12 3l-5 8h10z"/></svg>}
                {m.ikona === "document" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6M8 13h8M8 17h5"/></svg>}
                {m.ikona === "graduation" && <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 9l10-5 10 5-10 5z"/><path d="M6 11v5a6 6 0 0 0 12 0v-5"/></svg>}
              </div>
              <span class="text-[10px] font-semibold uppercase tracking-wider px-2 py-1 rounded-full sm:block hidden text-salmon-700/60 bg-salmon-100 dark:text-white/40 dark:bg-white/10">{m.kategoria}</span>
            </div>

            <h3 class="font-serif text-xl text-salmon-900 dark:text-white leading-tight">{m.tytul}</h3>
            <p class="mt-3 text-sm leading-relaxed text-justify text-salmon-900/75 dark:text-navy-300">{m.opis}</p>

            <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-salmon-700 group-hover:text-salmon-800 dark:text-salmon-300/80 dark:group-hover:text-salmon-300 transition">
              Otwórz
              <svg viewBox="0 0 24 24" class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="container-x pb-16 sm:pb-20">
    <div class="rounded-3xl border border-salmon-100 bg-white dark:border-white/10 dark:bg-white/5 p-6 sm:p-10">
      <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-6">
        <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-salmon-100 text-salmon-600 dark:bg-white/10 dark:text-navy-200">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
        </div>
        <div>
          <h3 class="font-serif text-2xl text-salmon-900 dark:text-white">Czegoś brakuje?</h3>
          <p class="mt-2 text-salmon-900/70 dark:text-navy-300">
            Pracujemy nad rozbudową strefy materiałów. Jeśli potrzebujesz konkretnego dokumentu lub
            materiału edukacyjnego - daj nam znać, postaramy się go przygotować.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
